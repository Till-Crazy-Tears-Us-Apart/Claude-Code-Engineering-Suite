# Logic Indexer Configuration
# Use ! prefix to exclude directories or files.
# Patterns ending with / match directories only.
# Supports fnmatch wildcards (*, ?).

!**/.git/
!**/node_modules/
!**/__pycache__/
!**/.claude_code/
!**/.claude/
!**/.ideas/
!**/.vscode/
!**/dist/
!**/build/
!tests/
!test/
!*.log
!*.pyc
!**/*.pyc
!**/.DS_Store
!**/venv/
!**/.compact_args.md
!**/LICENSE
!.gitignore

# C/C++ build artifacts
!**/*.o
!**/*.obj
!**/*.a
!**/*.so
!**/*.dylib
!**/*.dll
!**/*.lib
!**/*.exe
!**/CMakeFiles/
!**/CMakeCache.txt
!**/cmake_install.cmake
!**/compile_commands.json
!**/Makefile
!**/*.d

# TypeScript build artifacts
!**/*.d.ts
!**/*.js.map
!**/*.tsbuildinfo
